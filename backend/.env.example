# Copy to .env and edit as needed. Never commit .env.

# Ollama (local LLM — run `ollama serve` and `ollama pull llama3.1:8b` first)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_REQUEST_TIMEOUT=120

# Embedding model (must match what the index was built with)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval
TOP_K=8

# Storage
CHROMA_PERSIST_DIR=./data/chroma

# Logging
LOG_LEVEL=INFO
