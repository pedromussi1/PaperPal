# Copy to .env and edit as needed. Never commit .env.

# LLM provider: "ollama" (local, free, default) or "groq" (cloud, free tier)
LLM_PROVIDER=ollama

# --- Ollama (local) -----------------------------------------------------
# Used when LLM_PROVIDER=ollama. Run `ollama serve` and `ollama pull llama3.1:8b` first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_REQUEST_TIMEOUT=120

# --- Groq (cloud, free tier) --------------------------------------------
# Used when LLM_PROVIDER=groq. Get a free key at https://console.groq.com
# (no credit card). Free tier: 30 req/min, 14400 req/day.
# GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# --- Embeddings ---------------------------------------------------------
# Must match what the index was built with — changing invalidates the store.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking + retrieval -----------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=8

# --- Storage ------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma

# --- Logging ------------------------------------------------------------
LOG_LEVEL=INFO
